# Django Settings
ALLOWED_HOSTS=localhost,127.0.0.1
DEBUG=True
DJANGO_SECRET_KEY=change-me-in-production-use-secrets-generator
DJANGO_SETTINGS_MODULE=config.settings.development

# Database
DATABASE_URL=postgres://dignifi:dignifi_dev_password@localhost:5432/dignifi_dev

# CORS
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# Encryption (Generate with: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())")
FIELD_ENCRYPTION_KEY=GENERATE-FERNET-KEY-FOR-PRODUCTION

# District Configuration
DEFAULT_DISTRICT=ilnd

# External Services (TBD)
DOJ_COUNSELING_API_KEY=tbd

# ============================================
# OCR Configuration
# ============================================

# OCR Provider ('clarifai' for MVP, 'vllm' for production)
OCR_PROVIDER=clarifai

# Clarifai API (MVP/Development)
CLARIFAI_PAT=your-clarifai-personal-access-token

# vLLM Self-Hosted (Production - after GPU deployment)
# VLLM_BASE_URL=http://gpu-server:8000
# VLLM_API_KEY=optional-api-key

# Document Storage
DOCUMENT_STORAGE_BACKEND=filesystem  # 's3' for production

# Feature Flags
ENABLE_CHAPTER_11=False  # Set to True for business bankruptcy support
ENABLE_CHAPTER_13=False
